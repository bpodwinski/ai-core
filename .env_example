# DOMAIN_NAME and SUBDOMAIN together determine the public URL where n8n is accessible.
# Example: SUBDOMAIN=n8n and DOMAIN_NAME=example.com → https://n8n.example.com

# The main domain (or host:port in local development).
# In production, this should be your real domain (e.g., example.com).
DOMAIN_NAME=127.0.0.1:5678

# The subdomain used to serve n8n.
# In production, this is typically something like "n8n".
SUBDOMAIN=n8n

# Optional timezone used by Cron, Schedule Trigger, and other time-based nodes.
# Defaults to America/New_York if not set.
GENERIC_TIMEZONE=Europe/Paris

# Encryption key used by n8n to encrypt credentials in the database.
# MUST be at least 32 characters long and kept secret.
# Changing this after production use will invalidate stored credentials.
N8N_ENCRYPTION_KEY=someRandomStringThatIsAtLeast32CharactersLong

# Email address used for TLS/SSL certificate creation (if using automated certificate generation).
# Not required if you handle SSL externally (e.g., reverse proxy).
SSL_EMAIL=user@localhost.local

# =========================
# IMAP CONFIGURATION
# =========================

# IMAP server hostname (e.g., mail.infomaniak.com)
IMAP_HOST=mail.local

# Full email address used for IMAP authentication.
IMAP_USER=my@mail.local

# IMAP password.
# IMPORTANT: If the password starts with "$", escape it as "$$" in this file.
IMAP_PASS=password

# IMAP folder used as Trash / Deleted items.
IMAP_TRASH=Trash

# Default number of emails fetched per batch (pagination size).
IMAP_LIMIT=100

# Maximum number of characters extracted from email body (0 = headers only).
IMAP_BODY_MAX=5000

# =========================
# DATABASE CONFIGURATION
# =========================

# PostgreSQL superuser password.
# Must not be empty.
POSTGRES_PASSWORD=password

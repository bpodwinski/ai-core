REMOTE_USER=user
REMOTE_HOST=localhost
REMOTE_PORT=22
REMOTE_PATH=/home/user/public_html/mcp
SSH_KEY=~/.ssh/mcp_deploy

# Sur Windows, utiliser le SSH natif :
# SSH_CMD=C:/Windows/System32/OpenSSH/ssh.exe

# ── Installation de la restriction SSH (à faire une seule fois) ───────────────
#
# 1. Copier le wrapper sur le serveur :
#    scp mcp/deploy-remote.sh user@host:~/deploy-mcp.sh
#    ssh user@host "chmod 750 ~/deploy-mcp.sh && echo 'MCP_DEPLOY_PATH=/home/user/public_html/mcp' >> ~/.bashrc"
#
# 2. Récupérer la clé publique :
#    cat ~/.ssh/mcp_deploy.pub
#
# 3. Ajouter dans ~/.ssh/authorized_keys sur le serveur (remplacer USER et la clé) :
#    command="/home/USER/deploy-mcp.sh",no-port-forwarding,no-X11-forwarding,no-agent-forwarding,no-pty ssh-ed25519 AAAA...
#
# Tester : ssh -i ~/.ssh/mcp_deploy user@host "docker compose up -d --build --force-recreate"
# → doit fonctionner. Toute autre commande doit retourner "commande non autorisée".

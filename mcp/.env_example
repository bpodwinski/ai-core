MCP_TUNNEL_TOKEN=your_mcp_tunnel_token_here

# URL publique du domaine MCP (sans slash final)
OAUTH_ISSUER=https://mcp.benoitpodwinski.com

# Bearer token émis par OAuth après autorisation (min. 32 chars)
# Pour rotater : générer un nouveau secret, mettre à jour ici, puis : docker compose up -d
MCP_API_KEY=changeme_replace_with_a_long_random_secret

# Origines autorisées pour OAuth redirect_uri (virgule-séparées, sans slash final)
# Laisser vide = toutes les origines acceptées (dev seulement)
# Exemple prod : https://claude.ai,https://app.example.com
OAUTH_ALLOWED_ORIGINS=https://claude.ai

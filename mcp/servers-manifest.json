{
  "baseUrl": "https://mcp.benoitpodwinski.com",
  "mcpEndpoint": "/mcp",
  "mcpName": "docs",
  "docSources": [
    {
      "name": "leptos",
      "description": "Leptos framework — official book (github.com/leptos-rs/book)",
      "source": {
        "type": "git",
        "url": "https://github.com/leptos-rs/book",
        "docsPath": "src/"
      }
    },
    {
      "name": "leptos-use",
      "description": "Leptos-use — collection of utilities for Leptos (github.com/synphonyte/leptos-use)",
      "source": {
        "type": "git",
        "url": "https://github.com/synphonyte/leptos-use",
        "docsPath": "docs/book/src/"
      }
    },
    {
      "name": "rust",
      "description": "The Rust Programming Language book (github.com/rust-lang/book)",
      "source": {
        "type": "git",
        "url": "https://github.com/rust-lang/book",
        "docsPath": "src/"
      }
    },
    {
      "name": "daisyui",
      "description": "DaisyUI component library reference (daisyui.com/llms.txt)",
      "source": {
        "type": "url",
        "url": "https://daisyui.com/llms.txt",
        "transforms": ["split"]
      }
    },
    {
      "name": "induflow",
      "description": "InduFlow PartHub API documentation",
      "source": {
        "type": "local",
        "path": "induflow/"
      }
    },
    {
      "name": "ollama",
      "description": "Ollama — open-source local LLM framework documentation (github.com/ollama/ollama)",
      "source": {
        "type": "git",
        "url": "https://github.com/ollama/ollama",
        "docsPath": "docs/"
      }
    },
    {
      "name": "tailwindcss",
      "description": "Tailwind CSS v4 — docs + catalog complet des classes",
      "source": {
        "type": "git",
        "url": "https://github.com/tailwindlabs/tailwindcss.com",
        "docsPath": "src/docs/",
        "transforms": ["strip-mdx", "generate-catalog"]
      }
    }
  ],
  "stdio": [
    {
      "name": "ag-grid",
      "command": "npx",
      "args": ["-y", "-p", "ag-mcp@1.0.0", "-p", "ajv", "ag-mcp"],
      "description": "AG Grid documentation — search docs, detect version, examples"
    },
    {
      "name": "github",
      "command": "${USERPROFILE}/.claude/bin/github-mcp-server.exe",
      "args": ["stdio"],
      "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}" },
      "description": "GitHub — PRs, issues, repos, code search (github/github-mcp-server binary)"
    }
  ],
  "external": [
    {
      "name": "openai-docs",
      "url": "https://developers.openai.com/mcp",
      "description": "OpenAI developer documentation (API, Codex, ChatGPT Apps SDK)"
    }
  ]
}

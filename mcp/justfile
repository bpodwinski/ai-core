set windows-shell := ["powershell", "-NoProfile", "-Command"]

# Build all release binaries in the workspace
build:
    cargo build --release

# Check compilation without producing binaries
check:
    cargo check

# Build Docker image (single multi-tenant docs server)
docker-build:
    docker compose build mcp-docs

# Start the full stack locally
up:
    docker compose up -d --build

# Stop the stack
down:
    docker compose down

# Show logs (ex: just logs mcp-docs)
logs *ARGS:
    docker compose logs -f {{ARGS}}

# Deploy to remote server
deploy:
    powershell -NoProfile -ExecutionPolicy Bypass -File deploy.ps1

# Deploy to remote server (no Docker cache)
deploy-no-cache:
    powershell -NoProfile -ExecutionPolicy Bypass -File deploy.ps1 -NoCache

# Build + deploy
ship: docker-build deploy

# Build + deploy (force full rebuild, no Docker cache)
ship-no-cache: docker-build deploy-no-cache

# Restart a service (ex: just restart mcp-docs)
restart SERVICE:
    docker compose restart {{SERVICE}}

# Run integration tests (requires mcp-docs running)
test:
    docker compose up -d mcp-docs
    bash tests/test-cache-features.sh

{
  "mcpServers": {
    "docs": {
      "type": "http",
      "url": "https://mcp.benoitpodwinski.com/mcp"
    },
    "openai-docs": {
      "type": "http",
      "url": "https://developers.openai.com/mcp"
    },
    "ag-grid": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "ag-mcp"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@github/github-mcp-server",
        "stdio"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}

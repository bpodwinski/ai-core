{
  "mcpServers": {
    "docs": {
      "type": "http",
      "url": "https://mcp.benoitpodwinski.com/mcp"
    },
    "openai-docs": {
      "type": "http",
      "url": "https://developers.openai.com/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      }
    },
    "ag-grid": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "ag-mcp"
      ]
    }
  }
}

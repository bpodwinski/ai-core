{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "MCP: Build Rust",
      "type": "shell",
      "command": "just build",
      "options": { "cwd": "${workspaceFolder}/mcp" },
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "MCP: Check",
      "type": "shell",
      "command": "just check",
      "options": { "cwd": "${workspaceFolder}/mcp" },
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "MCP: Docker Build",
      "type": "shell",
      "command": "just docker-build",
      "options": { "cwd": "${workspaceFolder}/mcp" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "MCP: Up",
      "type": "shell",
      "command": "just up",
      "options": { "cwd": "${workspaceFolder}/mcp" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "MCP: Down",
      "type": "shell",
      "command": "just down",
      "options": { "cwd": "${workspaceFolder}/mcp" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "MCP: Logs",
      "type": "shell",
      "command": "just logs",
      "options": { "cwd": "${workspaceFolder}/mcp" },
      "group": "none",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "MCP: Deploy",
      "type": "shell",
      "command": "just deploy",
      "options": { "cwd": "${workspaceFolder}/mcp" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "MCP: Ship (Build + Deploy)",
      "type": "shell",
      "command": "just ship",
      "options": { "cwd": "${workspaceFolder}/mcp" },
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "MCP: Ship No Cache (Build + Deploy)",
      "type": "shell",
      "command": "just ship-no-cache",
      "options": { "cwd": "${workspaceFolder}/mcp" },
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "MCP: Restart Service",
      "type": "shell",
      "command": "just restart ${input:service}",
      "options": { "cwd": "${workspaceFolder}/mcp" },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "MCP: Test",
      "type": "shell",
      "command": "just test",
      "options": { "cwd": "${workspaceFolder}/mcp" },
      "group": "test",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "service",
      "type": "pickString",
      "description": "Service à redémarrer",
      "options": ["mcp-docs", "nginx", "cf-tunnel"],
      "default": "mcp-docs"
    }
  ]
}

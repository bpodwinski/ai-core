{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude/hooks/rust-check.py\"",
            "asyncRewake": true,
            "rewakeMessage": "cargo clippy found issues in the Rust file you just edited:",
            "statusMessage": "cargo fmt + clippy...",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
